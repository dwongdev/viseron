### kvazaar https://github.com/ultravideo/kvazaar
ARG KVAZAAR_VERSION
RUN \
  DIR=/tmp/kvazaar && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://github.com/ultravideo/kvazaar/archive/v${KVAZAAR_VERSION}.tar.gz && \
  tar -zx --strip-components=1 -f v${KVAZAAR_VERSION}.tar.gz
RUN ["cross-build-end"]
RUN \
  DIR=/tmp/kvazaar && \
