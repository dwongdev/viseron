### aom https://aomedia.googlesource.com/aom
FROM build as aom
ARG PREFIX
ARG AOM_VERSION
RUN \
  DIR=/tmp/aom && \
  git clone --branch v${AOM_VERSION} --depth 1 https://aomedia.googlesource.com/aom ${DIR} && \
  cd ${DIR} && \
  rm -rf CMakeCache.txt CMakeFiles && \
  mkdir -p ./aom_build && \
  cd ./aom_build && \
  cmake -DCMAKE_INSTALL_PREFIX="${PREFIX}" -DAOM_TARGET_CPU=arm -DENABLE_NEON=0 -DENABLE_TESTS=0 -DBUILD_SHARED_LIBS=OFF .. && \
  make && \
  make install && \
  rm -rf ${DIR}
### libxcb (and supporting libraries) for screen capture https://xcb.freedesktop.org/
ARG XORG_MACROS_VERSION
RUN \
  DIR=/tmp/xorg-macros && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://www.x.org/archive//individual/util/util-macros-${XORG_MACROS_VERSION}.tar.gz && \
  tar -zx --strip-components=1 -f util-macros-${XORG_MACROS_VERSION}.tar.gz && \
  ./configure --srcdir=${DIR} --prefix="${PREFIX}" && \
  make && \
  make install && \
  rm -rf ${DIR}

ARG XPROTO_VERSION
RUN \
  DIR=/tmp/xproto && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://www.x.org/archive/individual/proto/xproto-${XPROTO_VERSION}.tar.gz && \
  tar -zx --strip-components=1 -f xproto-${XPROTO_VERSION}.tar.gz && \
  ./configure --srcdir=${DIR} --prefix="${PREFIX}" && \
  make && \
  make install && \
  rm -rf ${DIR}

ARG XAU_VERSION
RUN \
  DIR=/tmp/libXau && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://www.x.org/archive/individual/lib/libXau-${XAU_VERSION}.tar.gz && \
  tar -zx --strip-components=1 -f libXau-${XAU_VERSION}.tar.gz && \
  ./configure --srcdir=${DIR} --prefix="${PREFIX}" && \
  make && \
  make install && \
  rm -rf ${DIR}

ARG LIBPTHREAD_STUBS_VERSION
RUN \
  DIR=/tmp/libpthread-stubs && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://xcb.freedesktop.org/dist/libpthread-stubs-${LIBPTHREAD_STUBS_VERSION}.tar.gz && \
  tar -zx --strip-components=1 -f libpthread-stubs-${LIBPTHREAD_STUBS_VERSION}.tar.gz && \
  ./configure --prefix="${PREFIX}" && \
  make && \
  make install && \
  rm -rf ${DIR}
### libxml2
ARG LIBXML2_VERSION
ARG LIBXML2_SHA256SUM
RUN \
  DIR=/tmp/libxml2 && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://gitlab.gnome.org/GNOME/libxml2/-/archive/v${LIBXML2_VERSION}/libxml2-v${LIBXML2_VERSION}.tar.gz && \
  echo ${LIBXML2_SHA256SUM} | sha256sum --check && \
  tar -xz --strip-components=1 -f libxml2-v${LIBXML2_VERSION}.tar.gz
RUN ["cross-build-end"]
RUN \
  DIR=/tmp/libxml2 && \
  cd ${DIR} && \
  ./autogen.sh --prefix="${PREFIX}" --with-ftp=no --with-http=no --with-python=no --enable-static --disable-shared
RUN ["cross-build-start"]
RUN \
  DIR=/tmp/libxml2 && \
  cd ${DIR} && \
  make && \
  make install && \
  rm -rf ${DIR}
### libzmq https://github.com/zeromq/libzmq/
FROM build as zmq
ARG PREFIX
ARG LIBZMQ_VERSION
ARG LIBZMQ_SHA256SUM
RUN \
  DIR=/tmp/libzmq && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sLO https://github.com/zeromq/libzmq/archive/v${LIBZMQ_VERSION}.tar.gz && \
  echo ${LIBZMQ_SHA256SUM} | sha256sum --check && \
  tar -xz --strip-components=1 -f v${LIBZMQ_VERSION}.tar.gz
RUN ["cross-build-end"]
RUN \
  DIR=/tmp/libzmq && \
  cd ${DIR} && \
  ./autogen.sh
RUN ["cross-build-start"]
RUN \
  DIR=/tmp/libzmq && \
  cd ${DIR} && \
  ./configure --prefix="${PREFIX}" --enable-static --disable-shared && \
  make && \
  make install && \
  rm -rf ${DIR}
### libpng http://www.libpng.org/pub/png/libpng.html
FROM build as libpng
ARG PREFIX
ARG LIBPNG_VERSION
RUN \
  DIR=/tmp/libpng && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -L https://downloads.sourceforge.net/project/libpng/libpng16/${LIBPNG_VERSION}/libpng-${LIBPNG_VERSION}.tar.xz | \
  tar -Jx --strip-components=1 && \
  ./configure --prefix="${PREFIX}" --enable-static --disable-shared && \
  make && \
  make install && \
  rm -rf ${DIR}
### libsrt https://github.com/Haivision/srt
FROM build as libsrt
ARG PREFIX
ARG LIBSRT_VERSION
RUN \
  DIR=/tmp/srt && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sL https://github.com/Haivision/srt/archive/refs/tags/v${LIBSRT_VERSION}.tar.gz | \
  tar -zx --strip-components=1 && \
  cmake -DCMAKE_INSTALL_PREFIX="${PREFIX}" -DENABLE_SHARED=OFF -DENABLE_STATIC=ON . && \
  make && \
  make install && \
  rm -rf ${DIR}
### libvmaf https://github.com/Netflix/vmaf
FROM build as libvmaf
ARG PREFIX
ARG LIBVMAF_VERSION
RUN \
  DIR=/tmp/vmaf && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sL https://github.com/Netflix/vmaf/archive/refs/tags/v${LIBVMAF_VERSION}.tar.gz | \
  tar -zx --strip-components=1 && \
  cd libvmaf && \
  meson setup \
  --prefix="${PREFIX}" \
  --buildtype=release \
  --default-library=static \
  --libdir="${PREFIX}/lib" \
  -Denable_tests=false \
  -Denable_docs=false \
  build && \
  ninja -C build && \
  ninja -C build install && \
  rm -rf ${DIR}
### libaribb24 https://github.com/nkoriyama/aribb24
FROM build as libaribb24
ARG PREFIX
ARG LIBARIBB24_VERSION
RUN \
  DIR=/tmp/b24 && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sL https://github.com/nkoriyama/aribb24/archive/refs/tags/v${LIBARIBB24_VERSION}.tar.gz | \
  tar -zx --strip-components=1 && \
  mkdir -p m4
RUN ["cross-build-end"]
RUN \
  DIR=/tmp/b24 && \
  cd ${DIR} && \
  autoreconf -fiv
RUN ["cross-build-start"]
RUN \
  DIR=/tmp/b24 && \
  cd ${DIR} && \
  ./configure CFLAGS="-I${PREFIX}/include -fPIC" --prefix="${PREFIX}" --enable-static --disable-shared && \
  make && \
  make install && \
  rm -rf ${DIR}
### zimg https://github.com/sekrit-twc/zimg
FROM build as zimg
ARG PREFIX
ARG ZIMG_VERSION
RUN \
  DIR=/tmp/zimg && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  curl -sL https://github.com/sekrit-twc/zimg/archive/refs/tags/release-${ZIMG_VERSION}.tar.gz | \
  tar -zx --strip-components=1
RUN ["cross-build-end"]
RUN \
  DIR=/tmp/zimg && \
  cd ${DIR} && \
  ./autogen.sh
RUN ["cross-build-start"]
RUN \
  DIR=/tmp/zimg && \
  cd ${DIR} && \
  ./configure --prefix="${PREFIX}" --enable-static --disable-shared && \
  make && \
  make install && \
  rm -rf ${DIR}
### userland https://github.com/raspberrypi/userland
FROM build as ffmpeg
ARG PREFIX
COPY --from=opencoreamr /opt/ffmpeg /opt/ffmpeg
COPY --from=vpx /opt/ffmpeg /opt/ffmpeg
COPY --from=webp /opt/ffmpeg /opt/ffmpeg
COPY --from=fdkaac /opt/ffmpeg /opt/ffmpeg
COPY --from=aom /opt/ffmpeg /opt/ffmpeg
COPY --from=zmq /opt/ffmpeg /opt/ffmpeg
COPY --from=libpng /opt/ffmpeg /opt/ffmpeg
COPY --from=libsrt /opt/ffmpeg /opt/ffmpeg
COPY --from=libvmaf /opt/ffmpeg /opt/ffmpeg
COPY --from=libaribb24 /opt/ffmpeg /opt/ffmpeg
COPY --from=zimg /opt/ffmpeg /opt/ffmpeg
RUN \
  DIR=/tmp/userland && \
  mkdir -p ${DIR} && \
  cd ${DIR} && \
  git clone --depth 1 https://github.com/raspberrypi/userland.git . && \
  ./buildme && \
  rm -rf ${DIR} && \
  echo "/opt/vc/lib" > /etc/ld.so.conf.d/00-vmcs.conf && \
  ldconfig
### ffmpeg https://ffmpeg.org/
ARG FFMPEG_VERSION
RUN  \
  ls -al /opt/ffmpeg && \
  DIR=/tmp/ffmpeg && mkdir -p ${DIR} && cd ${DIR} && \
  curl -sLO https://ffmpeg.org/releases/ffmpeg-${FFMPEG_VERSION}.tar.bz2 && \
  tar -jx --strip-components=1 -f ffmpeg-${FFMPEG_VERSION}.tar.bz2 && \
  DIR=/tmp/ffmpeg && mkdir -p ${DIR} && cd ${DIR} && \
  ./configure \
  --disable-debug \
  --disable-doc \
  --disable-ffplay \
  --enable-static \
  --disable-shared \
  --pkg-config-flags="--static" \
  --enable-libopencore-amrnb \
  --enable-libopencore-amrwb \
  --enable-gpl \
  --enable-libaribb24 \
  --enable-libass \
  --enable-fontconfig \
  --enable-libfreetype \
  --enable-libvidstab \
  --enable-libmp3lame \
  --enable-libopus \
  --enable-libsrt \
  --enable-libtheora \
  --enable-libvmaf \
  --enable-libvorbis \
  --enable-libvpx \
  --enable-libwebp \
  --enable-libxcb \
  --enable-libx265 \
  --enable-libxvid \
  --enable-libx264 \
  --enable-libzimg \
  --enable-nonfree \
  --enable-openssl \
  --enable-libfdk_aac \
  --enable-small \
  --enable-version3 \
  --enable-libzmq \
  --prefix="${PREFIX}" \
  --enable-libopenjpeg \
  --enable-libkvazaar \
  --enable-libaom \
  --enable-mmal \
  --enable-neon \
  --enable-omx \
  --enable-omx-rpi \
  --enable-v4l2_m2m \
  --extra-cflags="-I${PREFIX}/include" \
  --extra-ldflags="-L${PREFIX}/lib" \
  --extra-libs="-ldl -lpthread -lm -lz -lstdc++" && \
  make && \
  make install && \
  make tools/zmqsend && cp tools/zmqsend ${PREFIX}/bin/ && \
  make distclean && \
  hash -r && \
  cd tools && \
  make qt-faststart && cp qt-faststart ${PREFIX}/bin/

### cleanup
RUN \
  cp ${PREFIX}/bin/ffmpeg /usr/local/bin/ && \
  cp ${PREFIX}/bin/ffprobe /usr/local/bin/ && \
  cp ${PREFIX}/bin/zmqsend /usr/local/bin/ && \
  cp ${PREFIX}/bin/qt-faststart /usr/local/bin/ && \
  cp -r ${PREFIX}/share/ffmpeg /usr/local/share/

RUN [ "cross-build-end" ]

FROM scratch
COPY --from=ffmpeg /usr/local/bin /usr/local/bin/
COPY --from=ffmpeg /usr/local/share /usr/local/share/
COPY --from=ffmpeg /opt/vc/lib /opt/vc/lib
